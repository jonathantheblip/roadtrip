{
  "name": "roadtrip-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "set-secret": "node scripts/setSecret.mjs",
    "fetch-heroes": "node scripts/fetchHeroImages.mjs",
    "check-duplicates": "node scripts/checkDuplicates.mjs",
    "test": "node --test scripts/__tests__/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",

    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^9.1.0",
    "rehype-external-links": "^3.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.3.3",
    "sharp": "^0.34.5",
    "vite": "^5.4.10",
    "webdriverio": "^9.27.1"

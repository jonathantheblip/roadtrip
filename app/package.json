    "test:e2e:webkit": "playwright test --project=webkit-mobile",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:simulator": "node tests/simulator/runner.mjs"
  },
  "dependencies": {
    "exifr": "^7.1.3",

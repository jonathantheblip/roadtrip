# Playwright test artifacts (regenerated per run)
app/test-results/
app/playwright-report/
# Simulator-gate failure evidence (screenshots saved only on test failure)
app/tests/simulator/__artifacts__/
# Custom page.screenshot() captures — written by photos/claude specs for
# manual verify-in-DOM review, NOT asserted by any test. A full e2e run
# rewrites them with environment-dependent bytes (render + PNG encoding
# differ across machines / OS minor versions), so tracking them guarantees
# a dirty tree in CI. Untracked so the deploy gate stays clean. (journeys/
# step-captures live under here too and are likewise local-only.)
app/tests/e2e/screenshots/
app/node_modules
app/dist
app/.vite
worker/node_modules
worker/.wrangler
*.log
.DS_Store
.claude/
.env
.env.local
.env.*.local

# Built client artifact — published to GitHub Pages via Actions
# (.github/workflows/deploy-client.yml), NOT committed. See
# .github/DEPLOY_CLIENT_SETUP.md.
# CRITICAL: untrack docs/ (git rm --cached) ONLY AFTER Pages Source is
# switched to "GitHub Actions". Untracking while Pages still serves the
# docs/ FOLDER takes the live site down.
# Root-anchored (/docs/) so it matches ONLY the repo-root build output, NOT
# app/docs/ (tracked source + design specs).
/docs/
